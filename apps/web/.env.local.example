# === Stripe (server-side) ===
# Secret API key from Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Price IDs from Stripe Dashboard → Products → Prices
# Example IDs look like: price_1PabcdefGhijkLMNOP
STRIPE_PRICE_SINGLE=price_xxx_single
STRIPE_PRICE_FIVE_PACK=price_xxx_five_pack
STRIPE_PRICE_STACK=price_xxx_stack
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Base URL used for Stripe success/cancel redirects
# In production you can set this to https://ranch-link.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000
