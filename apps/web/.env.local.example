# === Stripe (server-side) ===
# Secret API key from Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Price IDs from Stripe Dashboard → Products → Prices
# Create a price for each product and paste the ID here
STRIPE_PRICE_SINGLE=price_xxx_single
STRIPE_PRICE_FIVE_PACK=price_xxx_five_pack
STRIPE_PRICE_STACK=price_xxx_stack
STRIPE_PRICE_LABEL_100=price_xxx_label_100
STRIPE_PRICE_TPP_1=price_xxx_tpp_1
STRIPE_PRICE_TPP_5=price_xxx_tpp_5
STRIPE_PRICE_TPP_15=price_xxx_tpp_15
STRIPE_PRICE_ORANGE_3=price_xxx_orange_3
STRIPE_PRICE_YELLOW_ABS_3=price_xxx_yellow_abs_3
STRIPE_PRICE_FLUORO_3=price_xxx_fluoro_3
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Stripe Dashboard → Developers → Webhooks → endpoint URL:
#   https://ranch-link.vercel.app/api/stripe/webhook
# Events: checkout.session.completed, checkout.session.async_payment_*, checkout.session.expired

# Resend (https://resend.com) — order confirmations, PIN codes, fulfillment emails
RESEND_API_KEY=re_xxx

# Email sender (must be a verified domain in Resend)
ORDER_EMAIL_FROM=RanchLink <solve@ranchlink.com>
CLAIM_EMAIL_FROM=RanchLink <solve@ranchlink.com>

# Comma-separated — notified on every NEW PAID order (ship-to + Superadmin link + customer ?k= link)
INTERNAL_OPS_EMAILS=solve@ranchlink.com,gonzalo@ritxma.com
# INTERNAL_OPS_EMAIL_FROM= — optional override for internal notification From (else ORDER_EMAIL_FROM / CLAIM_EMAIL_FROM / default)
# FULFILLMENT_EMAIL_ON_PACKED=1 — optional; default off — send customer email when order is marked packed

# Run in Supabase (if not already): ADD_STRIPE_ORDER_FULFILLMENT_FIELDS.sql, 008_STRIPE_ORDERS_INTERNAL_OPS.sql,
# 009_STRIPE_WEBHOOK_EMAIL_IDEMPOTENCY.sql, 010_ORDER_VIEW_SECRET.sql

# Portal / claim signed cookies (≥32 chars recommended)
# RANCHLINK_PORTAL_SECRET=
# SUPERADMIN_SESSION_SECRET=

# Base URL used for Stripe success/cancel redirects
# In production you can set this to https://ranch-link.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000
