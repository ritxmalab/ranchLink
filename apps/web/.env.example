# RanchLink — apps/web (.env.local)
# Copy to apps/web/.env.local. Never commit secrets.

# ── App URLs (production: https://ranch-link.vercel.app) ───────────────────
NEXT_PUBLIC_APP_URL=https://ranch-link.vercel.app
NEXT_PUBLIC_BASE_URL=https://ranch-link.vercel.app
NEXT_PUBLIC_BASE_PATH=

# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── Base + contracts (see .cursor/rules/ranchlink-architecture.mdc) ───────────
NEXT_PUBLIC_CHAIN_ID=8453
NEXT_PUBLIC_ALCHEMY_BASE_RPC=
ALCHEMY_BASE_RPC=
RANCHLINKTAG_ADDRESS=
RANCHLINKTAG_1155_ADDRESS=
NEXT_PUBLIC_CONTRACT_TAG=
SERVER_WALLET_ADDRESS=
RANCHLINK_PRIVATE_KEY=
# Or legacy naming:
# SERVER_WALLET_PRIVATE_KEY=

# ── IPFS ────────────────────────────────────────────────────────────────────
PINATA_JWT=

# ── Superadmin ─────────────────────────────────────────────────────────────
SUPERADMIN_USERNAME=
SUPERADMIN_PASSWORD=
SUPERADMIN_SESSION_SECRET=

# ── Stripe (store checkout) ─────────────────────────────────────────────────
# Webhook endpoint (production): https://YOUR_DOMAIN/api/stripe/webhook
# Events: checkout.session.completed, async_payment_*, checkout.session.expired
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs (Dashboard → Products → Price IDs)
STRIPE_PRICE_SINGLE=
STRIPE_PRICE_FIVE_PACK=
STRIPE_PRICE_STACK=
# Optional extra storefront tiers (if used in page.tsx / checkout)
# STRIPE_PRICE_LABEL_100=
# STRIPE_PRICE_TPP_1=
# STRIPE_PRICE_TPP_5=
# STRIPE_PRICE_TPP_15=
# STRIPE_PRICE_ORANGE_3=
# STRIPE_PRICE_YELLOW_ABS_3=
# STRIPE_PRICE_FLUORO_3=

# ── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY=
# From-address must be a verified domain in Resend
ORDER_EMAIL_FROM="RanchLink <solve@ranchlink.com>"
CLAIM_EMAIL_FROM=
# Comma-separated internal recipients when a customer pays (fulfillment alert)
INTERNAL_OPS_EMAILS="solve@ranchlink.com,gonzalo@ritxma.com"
# Optional separate From for internal-only mail (defaults to ORDER_EMAIL_FROM)
INTERNAL_OPS_EMAIL_FROM=
# Set to 1 to email customer when order is marked Packed (default: off)
FULFILLMENT_EMAIL_ON_PACKED=0

# ── Claim gate + ranch portal (signed cookies) ─────────────────────────────
RANCHLINK_PORTAL_SECRET=

# ── Optional ────────────────────────────────────────────────────────────────
# WALLET_ENCRYPTION_KEY=
# TAMACORE_INTERNAL_KEY=
